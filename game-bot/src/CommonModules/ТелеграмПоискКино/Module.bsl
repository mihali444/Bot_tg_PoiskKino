
#Область ПрограммныйИнтерфейс

// Обработчик элемента очереди в режиме работы бота - Тест с расшифровкой
// 
// Параметры:
//  ДанныеЭлемента - Структура
//  Отправитель - СправочникСсылка.УчетныеЗаписиТелеграм
Процедура ПриОбработкеЭлементаОчереди(ДанныеЭлемента, Отправитель) Экспорт

	ТекущийСтатус = РаботаСоСтатусом.СтатусОтправителя(Отправитель);

	Если ДанныеЭлемента.Свойство("callback_query") Тогда

		CallbackData = ДанныеЭлемента.callback_query.data;

		Если СтрНачинаетсяС(CallbackData, "film_facts_") Тогда
			ОбработатьДействиеСтраницыФактов(ДанныеЭлемента.callback_query, Отправитель, ТекущийСтатус);
			Возврат;
		КонецЕсли;

		Если СтрНачинаетсяС(CallbackData, "film_action_") Тогда
			ОбработатьДействиеСтраницыФильма(ДанныеЭлемента.callback_query, Отправитель, ТекущийСтатус);
			Возврат;
		КонецЕсли;

		Если СтрНачинаетсяС(CallbackData, "film_") Тогда
			ОбработатьВыборФильма(ДанныеЭлемента.callback_query, Отправитель, ТекущийСтатус);
			Возврат;
		КонецЕсли;

	КонецЕсли;

	Если ДанныеЭлемента.Свойство("message") Тогда

		Сообщение = ДанныеЭлемента.message;

		Если Не Сообщение.Свойство("from") Или Не Сообщение.Свойство("text") Тогда
			Возврат;
		КонецЕсли;

		Текст = Сообщение.text;

		Если ТекущийСтатус = Неопределено Или СтрНачинаетсяС(Текст, "/start") Тогда
			ОтправитьПриветствие(Отправитель);

		ИначеЕсли ТекущийСтатус.Статус = Перечисления.СтатусыПоискКино.Приветствие Тогда
			Если СтрНачинаетсяС(Текст, КомандаПоискПоКлючевойФразе()) Тогда
				ОтправитьВопросОКлючевойФразе(Отправитель);
			Иначе
				ОтправитьПриветствие(Отправитель);
			КонецЕсли;

		ИначеЕсли ТекущийСтатус.Статус = Перечисления.СтатусыПоискКино.ВводКлючевойФразы Тогда
			НачатьПоискКлючевойФразы(Отправитель, Текст, ТекущийСтатус);

		Иначе
			ОтправитьПриветствие(Отправитель);
		КонецЕсли;

	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции
Процедура ОбработатьДействиеСтраницыФактов(ДанныеCallback, Отправитель, ТекущийСтатус)
	
	Если ТекущийСтатус = Неопределено Тогда
		ТекущийСтатус = РаботаСоСтатусом.СтатусОтправителя(Отправитель);
	КонецЕсли;
	
	CallbackData = ДанныеCallback.data;
	
	ДанныеБезПрефикса = СтрЗаменить(CallbackData, "film_facts_", "");
	Части = СтрРазделить(ДанныеБезПрефикса, "_", Ложь);
	
	Если Части.Количество() < 2 Тогда
		Возврат;
	КонецЕсли;
	
	Действие = Части[0];
	FilmId = Части[1];
	НомерСтраницы = ?(Части.Количество() > 2, Число(Части[2]), 1);
	
	ИдентификаторЧата = ДанныеCallback.message.chat.id;
	ИдСообщения = ДанныеCallback.message.message_id;
	
	Если Действие = "show" Тогда
			// Первый показ фактов (страница 1)
			ПоказатьФактыОФильме(Отправитель, FilmId, ИдентификаторЧата, ИдСообщения, ТекущийСтатус, 1);
			
	ИначеЕсли Действие = "prev" Тогда
			// Предыдущая страница
			ПоказатьФактыОФильме(Отправитель, FilmId, ИдентификаторЧата, ИдСообщения, ТекущийСтатус, НомерСтраницы);
			
	ИначеЕсли Действие = "next" Тогда
			// Следующая страница
			ПоказатьФактыОФильме(Отправитель, FilmId, ИдентификаторЧата, ИдСообщения, ТекущийСтатус, НомерСтраницы);
			
	ИначеЕсли Действие = "back" Тогда
			// Возврат к странице фильма
			ВернутьсяКРодительскомуКонтексту(Отправитель, FilmId, ИдентификаторЧата, ИдСообщения, ТекущийСтатус);
		Иначе
			// Неизвестное действие
			Возврат;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработатьДействиеСтраницыФильма(ДанныеCallback, Отправитель, ТекущийСтатус)
	
	Если ТекущийСтатус = Неопределено Тогда
		ТекущийСтатус = РаботаСоСтатусом.СтатусОтправителя(Отправитель);
	КонецЕсли;
	
	ИдентификаторЧата = ДанныеCallback.message.chat.id;
	ИдСообщения = ДанныеCallback.message.message_id;
	
	Попытка
		ИнтеграцияТелеграм.РедактироватьСообщение(
			ИдентификаторЧата, ИдСообщения, "⏳ Загружаю...");
	Исключение
		ИнтеграцияТелеграм.УдалитьСообщение(ИдентификаторЧата, ИдСообщения);
		ИнформацияСообщения = ИнтеграцияТелеграм.ОтправитьСообщениеСВозвратомId(Отправитель ,"⏳ Загружаю...");
		Если ИнформацияСообщения.Успешно Тогда
			ИДСообщения = ИнформацияСообщения.ИдентификаторСообщения;
			ИдентификаторЧата = ИнформацияСообщения.ИдентификаторЧата;
		КонецЕсли;
	КонецПопытки;
	
	CallbackData = ДанныеCallback.data;
	
	ДанныеБезПрефикса = СтрЗаменить(CallbackData, "film_action_", "");
	ПозицияПодчёркивания = СтрНайти(ДанныеБезПрефикса, "_");
	
	Если ПозицияПодчёркивания = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Действие = Лев(ДанныеБезПрефикса, ПозицияПодчёркивания - 1);
	FilmId = Сред(ДанныеБезПрефикса, ПозицияПодчёркивания + 1);
	
	Если Действие = "facts" Тогда
		ПоказатьФактыОФильме(Отправитель, FilmId, ИдентификаторЧата, ИдСообщения, ТекущийСтатус, 1);
	ИначеЕсли Действие =  "awards" Тогда
//			ПоказатьНаградыФильма(Отправитель, FilmId, ИдентификаторЧата, ИдСообщения);
	ИначеЕсли Действие = "similar" Тогда
//			ПоказатьПохожиеФильмы(Отправитель, FilmId, ИдентификаторЧата, ИдСообщения);
	ИначеЕсли Действие = "gallery" Тогда
//			ПоказатьГалереюФильма(Отправитель, FilmId, ИдентификаторЧата, ИдСообщения);
	ИначеЕсли Действие = "reviews" Тогда
//			ПоказатьРецензииФильма(Отправитель, FilmId, ИдентификаторЧата, ИдСообщения);
	ИначеЕсли Действие = "back" Тогда
		ВернутьсяКРодительскомуКонтексту(Отправитель, FilmId, ИдентификаторЧата, ИдСообщения, ТекущийСтатус);	
	Иначе
		ВызватьИсключение "Неизвестное действие";
	КонецЕсли;
	
КонецПроцедуры

Процедура ВернутьсяКРодительскомуКонтексту(Отправитель, FilmId, ТекущийИдЧата, ТекущийИдСообщения, ТекущийСтатус)
	
	Если ТекущийСтатус = Неопределено Тогда
		ТекущийСтатус = РаботаСоСтатусом.СтатусОтправителя(Отправитель);
	КонецЕсли;
	
	Если ТекущийСтатус = Неопределено ИЛИ ТекущийСтатус.ДополнительныеДанные = Неопределено Тогда
		ОтправитьПриветствие(Отправитель);
		Возврат;
	КонецЕсли;
	
	Кеш = ТекущийСтатус.ДополнительныеДанные.Получить();
	
	Если Не Кеш.Свойство("РодительскийКонтекст") Тогда
		ОтправитьПриветствие(Отправитель);
		Возврат;
	КонецЕсли;
	
	Родитель = Кеш.РодительскийКонтекст;
	
	Если Родитель.Статус = Перечисления.СтатусыПоискКино.ВыборФильма Тогда
		ВосстановитьВыборФильма(Отправитель, Родитель.Данные, ТекущийИдЧата, ТекущийИдСообщения);
		
	ИначеЕсли Родитель.Статус = Перечисления.СтатусыПоискКино.СтраницаФильма Тогда
		ВосстановитьСтраницуФильма(Отправитель, Родитель.Данные, ТекущийИдЧата, ТекущийИдСообщения, ТекущийСтатус);
		
	Иначе
		ОтправитьПриветствие(Отправитель);
	КонецЕсли;
	
КонецПроцедуры

Процедура ВосстановитьВыборФильма(Отправитель, Данные, ИдЧата, ИдСообщения)
	
	МассивФильмов = Данные.МассивФильмов;
	ВсегоНайдено = Данные.ВсегоНайдено;
	
	ТекстСообщения = "🎬 Найдено: " + ВсегоНайдено + ". Выберите фильм:";
	Клавиатура = Клавиатуры.КлавиатураФильмовInline(МассивФильмов);
	
	ДопСвойства = ИнтеграцияТелеграм.ДополнительныеСвойстваИсходящегоСообщения();
	ДопСвойства.Клавиатура = Клавиатура;
	
	Попытка
		ИнтеграцияТелеграм.РедактироватьСообщение(
			ИдЧата, ИдСообщения, ТекстСообщения, ДопСвойства);
	Исключение
		ИнтеграцияТелеграм.УдалитьСообщение(ИдЧата, ИдСообщения);
		ИнтеграцияТелеграм.ОтправитьСообщение(Отправитель, ТекстСообщения, ДопСвойства);
	КонецПопытки;
	
	РаботаСоСтатусом.УстановитьСтатус(Отправитель, Перечисления.СтатусыПоискКино.ВыборФильма, Данные);
	
КонецПроцедуры

Процедура ВосстановитьСтраницуФильма(Отправитель, Данные, ТекущийИдЧата, ТекущийИдСообщения, ТекущийСтатус)
	
	Если Не Данные.Свойство("ИДФильма") ИЛИ Не Данные.Свойство("ТекстДеталей") Тогда
		ДеталиФильма = ЗапросДеталейФильмаПоId(Отправитель, Данные.ИДФильма);
		Если ДеталиФильма <> Неопределено Тогда
			ПоказатьДеталиФильма(Отправитель, ДеталиФильма, ТекущийИдСообщения, ТекущийИдЧата, ТекущийСтатус);
		Иначе
			ОтправитьПриветствие(Отправитель);
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	ИДФильма = Данные.ИДФильма;
	ТекстДеталей = Данные.ТекстДеталей;
	Обложка = ?(Данные.Свойство("Обложка"), Данные.Обложка, Неопределено);
	ИдЧата = ?(Данные.Свойство("ИдЧата"), Данные.ИдЧата, ТекущийИдЧата);
	
	Клавиатура = Клавиатуры.КлавиатураСтраницыФильма(ИДФильма);
	ДопСвойства = ИнтеграцияТелеграм.ДополнительныеСвойстваИсходящегоСообщения();
	ДопСвойства.Клавиатура = Клавиатура;
	
	Попытка
		Если Обложка <> Неопределено Тогда
			ИнтеграцияТелеграм.УдалитьСообщение(ИдЧата, ТекущийИдСообщения);
			ИнтеграцияТелеграм.ОтправитьКартинку(Отправитель, Обложка, ТекстДеталей, ДопСвойства);
		Иначе
			ИнтеграцияТелеграм.РедактироватьСообщение(
				ИдЧата, ТекущийИдСообщения, ТекстДеталей, ДопСвойства);
		КонецЕсли;
		
	Исключение
		Если Обложка <> Неопределено Тогда
			ИнтеграцияТелеграм.ОтправитьКартинку(Отправитель, Обложка, ТекстДеталей, ДопСвойства);
		Иначе
			ИнтеграцияТелеграм.ОтправитьСообщение(Отправитель, ТекстДеталей, ДопСвойства);
		КонецЕсли;
	КонецПопытки;
	
	КэшФильма = Новый Структура;
	КэшФильма.Вставить("ИДФильма", ИДФильма);
	КэшФильма.Вставить("ТекстДеталей", ТекстДеталей);
	КэшФильма.Вставить("Обложка", Обложка);
	КэшФильма.Вставить("ИдЧата", ИдЧата);
	КэшФильма.Вставить("ДатаКеширования", ТекущаяДатаСеанса());
	
	Если Данные.Свойство("РодительскийКонтекст") Тогда
		КэшФильма.Вставить("РодительскийКонтекст", Данные.РодительскийКонтекст);
	КонецЕсли;
	
	РаботаСоСтатусом.УстановитьСтатус(Отправитель, Перечисления.СтатусыПоискКино.СтраницаФильма, КэшФильма);
	
КонецПроцедуры

Процедура ПоказатьФактыОФильме(Отправитель, FilmId, ИдентификаторЧата, ИдСообщения, ТекущийСтатус, НомерСтраницы = 1)
	
	Если ТекущийСтатус = Неопределено Тогда
		ТекущийСтатус = РаботаСоСтатусом.СтатусОтправителя(Отправитель);
	КонецЕсли;
	
	КешФактов = Неопределено;
	
	Если ТекущийСтатус <> Неопределено И ТекущийСтатус.ДополнительныеДанные <> Неопределено Тогда
		ДанныеСтатуса = ТекущийСтатус.ДополнительныеДанные.Получить();
		Если ДанныеСтатуса.Свойство("МассивФактов") И ДанныеСтатуса.Свойство("FilmId") И ДанныеСтатуса.FilmId = FilmId Тогда
			КешФактов = ДанныеСтатуса;
		КонецЕсли;
	КонецЕсли;
	
	Если КешФактов = Неопределено Тогда
		
		ИнтеграцияТелеграм.РедактироватьСообщение(
			ИдентификаторЧата, ИдСообщения, "🤫 Загружаю интересные факты... ⏳");
		
		Ответ = ЗапросДеталейФильмаПоId(Отправитель, FilmId, "/facts");
		
		Если Ответ = Неопределено Тогда
			ИнтеграцияТелеграм.РедактироватьСообщение(
				ИдентификаторЧата, ИдСообщения, "😔 Не удалось загрузить факты. Попробуйте позже.");
			Возврат;
		КонецЕсли;
		
		ДанныеФактов = ОбработатьJSON(Отправитель, Ответ);
		
		Если Не ДанныеФактов.Свойство("items") Тогда
			ИнтеграцияТелеграм.РедактироватьСообщение(
				ИдентификаторЧата, ИдСообщения, "😔 Факты не найдены для этого фильма.");
			Возврат;
		КонецЕсли;
		
		КешФактов = Новый Структура;
		КешФактов.Вставить("FilmId", FilmId);
		КешФактов.Вставить("ВсегоФактов", ДанныеФактов["total"]);
		КешФактов.Вставить("МассивФактов", ДанныеФактов["items"]);
		КешФактов.Вставить("ТекущаяСтраница", 1);
		КешФактов.Вставить("ФактовНаСтранице", 3);
		
	Иначе
		КешФактов.ТекущаяСтраница = НомерСтраницы;
	КонецЕсли;
	
	ФактовНаСтранице = КешФактов.ФактовНаСтранице;
	НачальныйИндекс = (КешФактов.ТекущаяСтраница - 1) * ФактовНаСтранице;
	КонечныйИндекс = Мин(НачальныйИндекс + ФактовНаСтранице, КешФактов.ВсегоФактов);
	
	ТекстФактов = "🎬 <b>Интересные факты о фильме</b>" + Символы.ПС + Символы.ПС;
	
	Для Индекс = НачальныйИндекс По КонечныйИндекс - 1 Цикл
		Факт = КешФактов.МассивФактов[Индекс];
		ТипФакта = ?(Факт.Свойство("type"), Факт["type"], "FACT");
		ТекстФакта = Факт["text"];
		ТекстФакта = РаботаСТекстом.ОчиститьТекстОтHTML(ТекстФакта);
		Спойлер = ?(Факт.Свойство("spoiler"), Факт["spoiler"], Ложь);
		
		Эмодзи = "💡";
		Если ТипФакта = "BLOOPER" Тогда
			Эмодзи = "🎬";
		КонецЕсли;
		
		ТекстФактов = ТекстФактов + Эмодзи + " " + ТекстФакта + Символы.ПС;
	КонецЦикла;
	
	ВсегоСтраниц = Окр(КешФактов.ВсегоФактов / ФактовНаСтранице, 0, РежимОкругления.Окр15как20);
	
	Клавиатура = Клавиатуры.КлавиатураФактов(FilmId, КешФактов.ТекущаяСтраница, ВсегоСтраниц);
	ДопСвойства = ИнтеграцияТелеграм.ДополнительныеСвойстваИсходящегоСообщения();
	ДопСвойства.Клавиатура = Клавиатура;
	
	Попытка
		ИнтеграцияТелеграм.РедактироватьСообщение(
			ИдентификаторЧата, ИдСообщения, ТекстФактов, ДопСвойства);
	Исключение
		ИнтеграцияТелеграм.ОтправитьСообщение(Отправитель, ТекстФактов, ДопСвойства);
	КонецПопытки;
	
	Если ТекущийСтатус <> Неопределено И ТекущийСтатус.ДополнительныеДанные <> Неопределено Тогда
		// Сохраняем контекст, если пришли со страницы фильма
		Если ТекущийСтатус.Статус = Перечисления.СтатусыПоискКино.СтраницаФильма Тогда
			КешФактов.Вставить("РодительскийКонтекст", Новый Структура(
				"Статус, Данные",
				Перечисления.СтатусыПоискКино.СтраницаФильма,
				ТекущийСтатус.ДополнительныеДанные.Получить()));
		КонецЕсли;
	КонецЕсли;
	
	РаботаСоСтатусом.УстановитьСтатус(Отправитель, Перечисления.СтатусыПоискКино.ФактыОФильме, КешФактов);
	
КонецПроцедуры

Процедура ОтправитьВопросОКлючевойФразе(Отправитель)
	
	РаботаСоСтатусом.УстановитьСтатус(Отправитель, Перечисления.СтатусыПоискКино.ВводКлючевойФразы);
	
	ДополнительныеСвойства = ИнтеграцияТелеграм.ДополнительныеСвойстваИсходящегоСообщения();
	ДополнительныеСвойства.Клавиатура = Клавиатуры.УдалитьКлавиатуру();
	
	ТекстВопроса = НСтр("ru = 'Введите текст для поиска:'");
	ИнтеграцияТелеграм.ОтправитьСообщение(Отправитель, ТекстВопроса, ДополнительныеСвойства);
	
КонецПроцедуры

Процедура ОтправитьПриветствие(Отправитель)
	ТекстПриветствия = НСтр(
			"ru = '🎬 Добро пожаловать в ПоискКино! 
			|
			|Я ваш персональный помощник в мире кино. С моей помощью вы можете:
			|
			|🔍 Искать фильмы по названию или ключевым словам
			|🎭 Узнавать информацию об актёрах
			|📚 Получать интересные факты о фильмах
			|🎥 Находить похожие фильмы
			|🖼️ Получать изображения:
			|   • Кадры из фильмов и со съёмок
			|   • Постеры и обложки
			|   • Фан-арты и концепт-арты
			|   • Промо-материалы и обои
			|   • Скриншоты
			|✍️ Читать рецензии
			|
			|Начните поиск прямо сейчас 👇'");
	ДополнительныеСвойства = ИнтеграцияТелеграм.ДополнительныеСвойстваИсходящегоСообщения();
	ДополнительныеСвойства.Клавиатура = Клавиатуры.КлавиатураОднаКнопка(КомандаПоискПоКлючевойФразе());

	ИнтеграцияТелеграм.ОтправитьСообщение(Отправитель, ТекстПриветствия, ДополнительныеСвойства);

	РаботаСоСтатусом.УстановитьСтатус(Отправитель, Перечисления.СтатусыПоискКино.Приветствие);

КонецПроцедуры

Процедура НачатьПоискКлючевойФразы(Отправитель, Текст, ТекущийСтатус)
	
	Если ТекущийСтатус = Неопределено Тогда
		ТекущийСтатус = РаботаСоСтатусом.СтатусОтправителя(Отправитель);
	КонецЕсли;
	
	ДополнительныеСвойства = ИнтеграцияТелеграм.ДополнительныеСвойстваИсходящегоСообщения();
	
	ТекстСообщения = СтрШаблон("Начинаю поиск по ключевой фразе: %1", Текст);
	ДанныеСообщения = ИнтеграцияТелеграм.ОтправитьСообщениеСВозвратомId(Отправитель, 
																		ТекстСообщения, 
																		ДополнительныеСвойства);
	ИдСообщения = ДанныеСообщения.ИдентификаторСообщения;
	ИдЧата = ДанныеСообщения.ИдентификаторЧата;
	
	Результат = ЗапросКСерверуПоискКлючевойФразы(Отправитель, Текст);
	
	Если Результат = 1 Тогда
		ТекстСообщения = СтрШаблон("😔 По запросу ""%1"" фильмы не найдены. Попробуйте другой запрос.", Текст);
		ДополнительныеСвойства = ИнтеграцияТелеграм.ДополнительныеСвойстваИсходящегоСообщения();
		ДополнительныеСвойства.Клавиатура = Клавиатуры.КлавиатураОднаКнопка(КомандаПоискПоКлючевойФразе());
		
		Попытка
			ИнтеграцияТелеграм.РедактироватьСообщение(ИдЧата, ИдСообщения, ТекстСообщения, ДополнительныеСвойства);
		Исключение
			ИнтеграцияТелеграм.ОтправитьСообщение(Отправитель, ТекстСообщения, ДополнительныеСвойства);
		КонецПопытки;
		
		РаботаСоСтатусом.УстановитьСтатус(Отправитель, Перечисления.СтатусыПоискКино.ВводКлючевойФразы);
		
		Возврат;
		
	ИначеЕсли Результат = 2 Тогда
		ТекстСообщения = СтрШаблон("Ошибка поиска по ключевой фразе ""%1"", попробуйте ещё раз", Текст);
		ДополнительныеСвойства = ИнтеграцияТелеграм.ДополнительныеСвойстваИсходящегоСообщения();
		ДополнительныеСвойства.Клавиатура = Клавиатуры.КлавиатураОднаКнопка(КомандаПоискПоКлючевойФразе());
		
		Попытка
			ИнтеграцияТелеграм.РедактироватьСообщение(ИдЧата, ИдСообщения, ТекстСообщения, ДополнительныеСвойства);
		Исключение
			ИнтеграцияТелеграм.ОтправитьСообщение(Отправитель, ТекстСообщения, ДополнительныеСвойства);
		КонецПопытки;
		
		РаботаСоСтатусом.УстановитьСтатус(Отправитель, Перечисления.СтатусыПоискКино.ВводКлючевойФразы);
		
		Возврат;
		
	Иначе
		
		ОбработанныйРезультат = ОбработатьJSON(Отправитель, Результат);
		
		ПоказатьРезультатыПоиска(Отправитель, ОбработанныйРезультат, ИдСообщения, ИдЧата);
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ПоказатьРезультатыПоиска(Отправитель, ОбработанныйРезультат, ИдСообщения, ИдЧата)

	МассивФильмов = Новый Массив;
	Счётчик = 0;
	
	Для Каждого Фильм Из ОбработанныйРезультат["films"] Цикл
		Если Счётчик >= 5 Тогда Прервать; КонецЕсли;
		
		СтруктураФильма = Новый Структура;
		СтруктураФильма.Вставить("id", Строка(Фильм["filmId"]));
		СтруктураФильма.Вставить("Название", ?(Фильм.Свойство("nameRu"), Фильм["nameRu"], Фильм["nameEn"]));
		СтруктураФильма.Вставить("ГодВыпуска", ?(Фильм.Свойство("year") И Фильм["year"] <> "null", Фильм["year"], ""));
		
		МассивФильмов.Добавить(СтруктураФильма);
		Счётчик = Счётчик + 1;
	КонецЦикла;
	
	Если МассивФильмов.Количество() = 0 Тогда
		ТекстСообщения = "😔 Фильмы не найдены. Попробуйте другой запрос."; 
		ИнтеграцияТелеграм.РедактироватьСообщение(ИдЧата, ИдСообщения, ТекстСообщения);
		Возврат;
	КонецЕсли;

	ТекстСообщения = "🎬 Найдено: " + ОбработанныйРезультат["searchFilmsCountResult"] + ". Выберите фильм:";

	Клавиатура = Клавиатуры.КлавиатураФильмовInline(МассивФильмов);

	ДополнительныеСвойства = ИнтеграцияТелеграм.ДополнительныеСвойстваИсходящегоСообщения();
	ДополнительныеСвойства.Клавиатура = Клавиатура;
	
	Попытка
		ИнтеграцияТелеграм.РедактироватьСообщение(ИдЧата, ИдСообщения, ТекстСообщения, ДополнительныеСвойства);
	Исключение
		ИнтеграцияТелеграм.ОтправитьСообщение(Отправитель, ТекстСообщения, ДополнительныеСвойства);
	КонецПопытки;
	
	СтруктураДанных = Новый Структура;
	СтруктураДанных.Вставить("МассивФильмов", МассивФильмов);
	СтруктураДанных.Вставить("ВсегоНайдено", ОбработанныйРезультат["searchFilmsCountResult"]);

	РаботаСоСтатусом.УстановитьСтатус(Отправитель, Перечисления.СтатусыПоискКино.ВыборФильма, СтруктураДанных);
	
КонецПроцедуры

Процедура ОбработатьВыборФильма(ДанныеCallback, Отправитель, ТекущийСтатус)
	
	Если ТекущийСтатус = Неопределено Тогда
		ТекущийСтатус = РаботаСоСтатусом.СтатусОтправителя(Отправитель);
	КонецЕсли;
		
	CallbackData = ДанныеCallback.data;
	Если Не СтрНачинаетсяС(CallbackData, "film_") Тогда
		Возврат;
	КонецЕсли;
	
	ТекстСообщения = "Собираю данные по фильму...";
	
	ИДСообщения = ДанныеCallback.message.message_id;
	ИдПользователя = ДанныеCallback.from.id;
	ИнтеграцияТелеграм.РедактироватьСообщение(ИдПользователя, ИДСообщения, ТекстСообщения);
	
	FilmId = РаботаСТекстом.ОчиститьИдентификатор(CallbackData, "film_");
	
	ДеталиФильма = ЗапросДеталейФильмаПоId(Отправитель, FilmId);
	
	Если ДеталиФильма = Неопределено Тогда
		ИнтеграцияТелеграм.РедактироватьСообщение(ИдПользователя, 
												  ИДСообщения, 
												  "❌ Не удалось загрузить информацию о фильме. Попробуйте ещё раз.");
		РаботаСоСтатусом.УстановитьСтатус(Отправитель, Перечисления.СтатусыПоискКино.ВыборФильма);
		Возврат;
	КонецЕсли;
	
	ПоказатьДеталиФильма(Отправитель, ДеталиФильма, ИДСообщения, ИдПользователя, ТекущийСтатус);
КонецПроцедуры

Процедура ПоказатьДеталиФильма(Отправитель, ДеталиФильма, ИДСообщения, ИдПользователя, ТекущийСтатус)
	
	Если ТекущийСтатус = Неопределено Тогда
		ТекущийСтатус = РаботаСоСтатусом.СтатусОтправителя(Отправитель);
	КонецЕсли;
	
	Фильм = ОбработатьJSON(Отправитель, ДеталиФильма);
	
	Обложка = ПолучитьДвоичныеДанныеОбложки(?(Фильм.Свойство("posterUrlPreview"), 
									   Фильм["posterUrlPreview"], 
									   Фильм["posterUrl"]));
	
	Название = ?(Фильм.Свойство("nameRu"), Фильм["nameRu"], Фильм["nameOriginal"]);
	ГодВыпуска = СтрЗаменить(?(Фильм.Свойство("year"), Фильм["year"], "-"), Символы.НПП, "");
	Рейтинг = ?(Фильм.Свойство("ratingKinopoisk"), Фильм["ratingKinopoisk"], Фильм["ratingImdb"]);
	Описание = Фильм["description"];
	БезопасноеОписание = РаботаСТекстом.ЭкранироватьHTML(Описание);
	Жанры = Фильм["genres"];
	
	МассивЖанров = Новый Массив;
	Для Каждого Строка Из Жанры Цикл
		МассивЖанров.Добавить(Строка["genre"]);
	КонецЦикла;
	ЖанрыСтрока = СтрСоединить(МассивЖанров, ", ");
	
	Страны = Фильм["countries"];
	МассивСтран = Новый Массив;
	Для Каждого Строка Из Страны Цикл
		МассивСтран.Добавить(Строка["country"]);
	КонецЦикла;
	
	СтраныСтрока = СтрСоединить(МассивСтран, ", ");
	
	ТекстДеталей = СтрШаблон("
			|🎬 <b>%1</b> %2
			|
			|⭐ <b>Рейтинг:</b> %3
			|🌍 %4
			|🎭 %5
			|
			|<b>Описание:</b> <i>%6</i>",
			Название,
			ГодВыпуска,
			Рейтинг,
			СтраныСтрока,
			ЖанрыСтрока,
			СокрЛП(БезопасноеОписание));
	
	ИДФильма = РаботаСТекстом.ОчиститьИдентификатор(Фильм["kinopoiskId"], " ");
	
	Клавиатура = Клавиатуры.КлавиатураСтраницыФильма(ИДФильма);

	ДополнительныеСвойства = ИнтеграцияТелеграм.ДополнительныеСвойстваИсходящегоСообщения();
	ДополнительныеСвойства.Клавиатура = Клавиатура;
	
	МаксДлинаСообщения = 1024;
	
	Если Обложка = Неопределено Тогда
		ИнтеграцияТелеграм.РедактироватьСообщение(ИдПользователя, ИДСообщения, ТекстДеталей, ДополнительныеСвойства);
	Иначе
		Если СтрДлина(ТекстДеталей) > МаксДлинаСообщения Тогда
			ТекстДеталей = РаботаСТекстом.ОбрезатьТекстДляПодписи(ТекстДеталей, МаксДлинаСообщения);
		КонецЕсли;
		ИнтеграцияТелеграм.УдалитьСообщение(ИдПользователя, ИДСообщения);
		ИнтеграцияТелеграм.ОтправитьКартинку(Отправитель, Обложка, ТекстДеталей, ДополнительныеСвойства);
	КонецЕсли;
	
	РодительскийКонтекст = Неопределено;
	
	Если ТекущийСтатус <> Неопределено И ТекущийСтатус.ДополнительныеДанные <> Неопределено Тогда
		Если ТекущийСтатус.Статус = Перечисления.СтатусыПоискКино.ВыборФильма Тогда
			РодительскийКонтекст = Новый Структура;
			РодительскийКонтекст.Вставить("Статус", Перечисления.СтатусыПоискКино.ВыборФильма);
			РодительскийКонтекст.Вставить("Данные", ТекущийСтатус.ДополнительныеДанные.Получить());
		КонецЕсли;
	КонецЕсли;
	
	КэшФильма = Новый Структура;
	КэшФильма.Вставить("ИДФильма", ИДФильма);
	КэшФильма.Вставить("ТекстДеталей", ТекстДеталей);
	КэшФильма.Вставить("Обложка", Обложка);
	КэшФильма.Вставить("ИдЧата", ИдПользователя);
	КэшФильма.Вставить("ДатаКеширования", ТекущаяДатаСеанса());
	
	Если РодительскийКонтекст <> Неопределено Тогда
		КэшФильма.Вставить("РодительскийКонтекст", РодительскийКонтекст);
	КонецЕсли;
	
	РаботаСоСтатусом.УстановитьСтатус(Отправитель, Перечисления.СтатусыПоискКино.СтраницаФильма, КэшФильма);
	
КонецПроцедуры

Функция ПолучитьДвоичныеДанныеОбложки(URLартинки)
	
	АдресБезПротокола = СтрЗаменить(URLартинки, "https://", "");
	АдресСервера = Лев(АдресБезПротокола, СтрНайти(АдресБезПротокола, "/") - 1);
	СсылкаБезАдреса = Сред(АдресБезПротокола, СтрНайти(АдресБезПротокола, "/"));

	
	HTTPСоединение = Новый HTTPСоединение(АдресСервера, , , , , Истина);
		
	HTTPЗапрос = Новый HTTPЗапрос(СсылкаБезАдреса);
	
	HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json");
	HTTPЗапрос.Заголовки.Вставить("X-API-KEY", Константы.КлючAPIКиноПоиск.Получить());
	
	//@skip-check bsl-legacy-check-dynamic-feature-access - Асинх только на клиенте
	Ответ = HTTPСоединение.Получить(HTTPЗапрос);
	
	Если Ответ.КодСостояния = 200 Тогда
		Возврат Ответ.ПолучитьТелоКакДвоичныеДанные();
	ИначеЕсли Ответ.КодСостояния = 301 ИЛИ Ответ.КодСостояния = 302 Тогда
		Возврат ПолучитьДвоичныеДанныеОбложки(Ответ.Заголовки["Location"]);
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

Функция ОбработатьJSON(Отправитель, Результат)
	
	СтрокаJSON = Результат.ПолучитьТелоКакСтроку();
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
	
	Попытка
		Результат = ПрочитатьJSON(ЧтениеJSON);
	Исключение
		Возврат "Не удалось прочитать JSON";
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция ЗапросКСерверуПоискКлючевойФразы(Отправитель, Текст)
	
	АдресСервера = Константы.АдресСервера.Получить();
	КлючеваяФраза = КодироватьСтроку(Текст, СпособКодированияСтроки.URLВКодировкеURL);
	
	Метод = "/api/v2.1/films/search-by-keyword";
	
	МетодСФразой = Метод + "?keyword=" + КлючеваяФраза;
	
	HTTPСоединение = Новый HTTPСоединение(АдресСервера, , , , , Истина);
	
	HTTPЗапрос = Новый HTTPЗапрос(МетодСФразой);
	
	HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json");
	HTTPЗапрос.Заголовки.Вставить("X-API-KEY", Константы.КлючAPIКиноПоиск.Получить());
	
	//@skip-check bsl-legacy-check-dynamic-feature-access - Асинх только на клиенте
	Ответ = HTTPСоединение.Получить(HTTPЗапрос);
	
	Если Ответ.КодСостояния = 200 Тогда
		Возврат Ответ;
	ИначеЕсли Ответ.КодСостояния = 404 Тогда
		Возврат 1;
	Иначе
		Возврат 2;
	КонецЕсли;
		
	
КонецФункции

Функция ЗапросДеталейФильмаПоId(Отправитель, FilmId, Страница = Неопределено)
	
	АдресСервера = Константы.АдресСервера.Получить();

	Метод = "/api/v2.2/films/";
	Если Страница = Неопределено Тогда
		МетодСИД = Метод + Строка(FilmId);
	Иначе
		МетодСИД = Метод + Строка(FilmId) + Строка(Страница);
	КонецЕсли;
	
	HTTPСоединение = Новый HTTPСоединение(АдресСервера, , , , , Истина);
	
	HTTPЗапрос = Новый HTTPЗапрос(МетодСИД);
	
	HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json");
	HTTPЗапрос.Заголовки.Вставить("X-API-KEY", Константы.КлючAPIКиноПоиск.Получить());
	
	//@skip-check bsl-legacy-check-dynamic-feature-access - Асинх только на клиенте
	Ответ = HTTPСоединение.Получить(HTTPЗапрос);
	
	Если Ответ.КодСостояния = 200 Тогда
		Возврат Ответ;
	Иначе
		ДополнительныеСвойства = ИнтеграцияТелеграм.ДополнительныеСвойстваИсходящегоСообщения();
		ДополнительныеСвойства.Клавиатура = Клавиатуры.КлавиатураОднаКнопка(КомандаПоискПоКлючевойФразе());
		ИнтеграцияТелеграм.ОтправитьСообщение(Отправитель, "😔 Ошибка поиска на сервере.
															|Попробуйте ещё раз.", ДополнительныеСвойства);
		РаботаСоСтатусом.УстановитьСтатус(Отправитель, Перечисления.СтатусыПоискКино.Приветствие);
	КонецЕсли;
КонецФункции

Функция КомандаПоискПоКлючевойФразе()
	Возврат НСтр("ru = 'Поиск по названию / ключевой фразе'");
КонецФункции

#КонецОбласти


#Область ПрограммныйИнтерфейс

// Обработчик элемента очереди в режиме работы бота - Тест с расшифровкой
// 
// Параметры:
//  ДанныеЭлемента - Структура
//  Отправитель - СправочникСсылка.УчетныеЗаписиТелеграм
Процедура ПриОбработкеЭлементаОчереди(ДанныеЭлемента, Отправитель) Экспорт

	ТекущийСтатус = РаботаСоСтатусом.СтатусОтправителя(Отправитель);

	Если ДанныеЭлемента.Свойство("callback_query") Тогда

		CallbackData = ДанныеЭлемента.callback_query.data;
		Если СтрНачинаетсяС(CallbackData, "film_") Тогда
			
			Если СтрНачинаетсяС(CallbackData, "film_facts_") Тогда
				ОбработатьДействиеСтраницыФактовФильма(ДанныеЭлемента.callback_query, Отправитель, ТекущийСтатус);
				Возврат;
			КонецЕсли;
	
			Если СтрНачинаетсяС(CallbackData, "film_action_") Тогда
				ОбработатьДействиеСтраницыФильма(ДанныеЭлемента.callback_query, Отправитель, ТекущийСтатус);
				Возврат;
			КонецЕсли;
	
			Если СтрНачинаетсяС(CallbackData, "film_") Тогда
				ОбработатьВыборФильма(ДанныеЭлемента.callback_query, Отправитель, ТекущийСтатус);
				Возврат;
			КонецЕсли;
			
		ИначеЕсли СтрНачинаетсяС(CallbackData, "actor_") Тогда
			
			Если СтрНачинаетсяС(CallbackData, "actor_facts_") Тогда
				ОбработатьДействиеСтраницыФактовАктера(ДанныеЭлемента.callback_query, Отправитель, ТекущийСтатус);
				Возврат;
			КонецЕсли;
			
			Если СтрНачинаетсяС(CallbackData, "actor_action_") Тогда
				ОбработатьДействиеСтраницыАктера(ДанныеЭлемента.callback_query, Отправитель, ТекущийСтатус);
				Возврат;
			КонецЕсли;
			
			Если СтрНачинаетсяС(CallbackData, "actor_") Тогда
				ОбработатьВыборАктера(ДанныеЭлемента.callback_query, Отправитель, ТекущийСтатус);
				Возврат;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;

	Если ДанныеЭлемента.Свойство("message") Тогда

		Сообщение = ДанныеЭлемента.message;

		Если Не Сообщение.Свойство("from") Или Не Сообщение.Свойство("text") Тогда
			Возврат;
		КонецЕсли;

		Текст = Сообщение.text;

		Если ТекущийСтатус = Неопределено Или СтрНачинаетсяС(Текст, "/start") Тогда
			ОтправитьПриветствие(Отправитель);

		ИначеЕсли ТекущийСтатус.Статус = Перечисления.СтатусыПоискКино.Приветствие Тогда
			Если Текст = КомандаПоискФильма() Тогда
				ОтправитьВопросОПоискеФильма(Отправитель);
			ИначеЕсли Текст = КомандаПоискАктёра() Тогда
				ОтправитьВопросОПоискеАктёра(Отправитель);
			Иначе
				ОтправитьПриветствие(Отправитель);
			КонецЕсли;

		ИначеЕсли ТекущийСтатус.Статус = Перечисления.СтатусыПоискКино.ВводФразыФильм Тогда
			НачатьПоискФильма(Отправитель, Текст, ТекущийСтатус);
		ИначеЕсли ТекущийСтатус.Статус = Перечисления.СтатусыПоискКино.ВводФразыАктёр Тогда
			НачатьПоискАктера(Отправитель, Текст, ТекущийСтатус);
		Иначе
			ОтправитьПриветствие(Отправитель);
		КонецЕсли;

	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции
Процедура ОбработатьДействиеСтраницыФактовФильма(ДанныеCallback, Отправитель, ТекущийСтатус)
	
	Если ТекущийСтатус = Неопределено Тогда
		ТекущийСтатус = РаботаСоСтатусом.СтатусОтправителя(Отправитель);
	КонецЕсли;
	
	CallbackData = ДанныеCallback.data;
	
	ДанныеБезПрефикса = СтрЗаменить(CallbackData, "film_facts_", "");
	Части = СтрРазделить(ДанныеБезПрефикса, "_", Ложь);
	
	Если Части.Количество() < 2 Тогда
		Возврат;
	КонецЕсли;
	
	Действие = Части[0];
	FilmId = Части[1];
	НомерСтраницы = ?(Части.Количество() > 2, Число(Части[2]), 1);
	
	ИдентификаторЧата = ДанныеCallback.message.chat.id;
	ИдСообщения = ДанныеCallback.message.message_id;
	
	Если Действие = "show" Тогда
			// Первый показ фактов (страница 1)
			ПоказатьФактыОФильме(Отправитель, FilmId, ИдентификаторЧата, ИдСообщения, ТекущийСтатус, 1);
			
	ИначеЕсли Действие = "prev" Тогда
			// Предыдущая страница
			ПоказатьФактыОФильме(Отправитель, FilmId, ИдентификаторЧата, ИдСообщения, ТекущийСтатус, НомерСтраницы);
			
	ИначеЕсли Действие = "next" Тогда
			// Следующая страница
			ПоказатьФактыОФильме(Отправитель, FilmId, ИдентификаторЧата, ИдСообщения, ТекущийСтатус, НомерСтраницы);
			
	ИначеЕсли Действие = "back" Тогда
			// Возврат к странице фильма
			ВернутьсяКРодительскомуКонтекстуФильма(Отправитель, FilmId, ИдентификаторЧата, ИдСообщения, ТекущийСтатус);
		Иначе
			// Неизвестное действие
			Возврат;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработатьДействиеСтраницыФактовАктера(ДанныеCallback, Отправитель, ТекущийСтатус)
	
	Если ТекущийСтатус = Неопределено Тогда
		ТекущийСтатус = РаботаСоСтатусом.СтатусОтправителя(Отправитель);
	КонецЕсли;
	
	CallbackData = ДанныеCallback.data;
	
	ДанныеБезПрефикса = СтрЗаменить(CallbackData, "actor_facts_", "");
	Части = СтрРазделить(ДанныеБезПрефикса, "_", Ложь);
	
	Если Части.Количество() < 2 Тогда
		Возврат;
	КонецЕсли;
	
	Действие = Части[0];
	ActorId = Части[1];
	НомерСтраницы = ?(Части.Количество() > 2, Число(Части[2]), 1);
	
	ИдентификаторЧата = ДанныеCallback.message.chat.id;
	ИдСообщения = ДанныеCallback.message.message_id;
	
	Если Действие = "show" Тогда
		ПоказатьФактыОбАктере(Отправитель, ActorId, ИдентификаторЧата, ИдСообщения, ТекущийСтатус, 1);
		
	ИначеЕсли Действие = "prev" Тогда
		ПоказатьФактыОбАктере(Отправитель, ActorId, ИдентификаторЧата, ИдСообщения, ТекущийСтатус, НомерСтраницы);
		
	ИначеЕсли Действие = "next" Тогда
		ПоказатьФактыОбАктере(Отправитель, ActorId, ИдентификаторЧата, ИдСообщения, ТекущийСтатус, НомерСтраницы);
		
	ИначеЕсли Действие = "back" Тогда
		
		ВернутьсяКРодительскомуКонтекстуАктера(Отправитель, ActorId, ИдентификаторЧата, ИдСообщения, ТекущийСтатус);
		
	Иначе
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработатьДействиеСтраницыФильма(ДанныеCallback, Отправитель, ТекущийСтатус)
	
	Если ТекущийСтатус = Неопределено Тогда
		ТекущийСтатус = РаботаСоСтатусом.СтатусОтправителя(Отправитель);
	КонецЕсли;
	
	ИдентификаторЧата = ДанныеCallback.message.chat.id;
	ИдСообщения = ДанныеCallback.message.message_id;
	
	Попытка
		ИнтеграцияТелеграм.РедактироватьСообщение(
			ИдентификаторЧата, ИдСообщения, "⏳ Загружаю...");
	Исключение
		ИнтеграцияТелеграм.УдалитьСообщение(ИдентификаторЧата, ИдСообщения);
		ИнформацияСообщения = ИнтеграцияТелеграм.ОтправитьСообщениеСВозвратомId(Отправитель ,"⏳ Загружаю...");
		Если ИнформацияСообщения.Успешно Тогда
			ИДСообщения = ИнформацияСообщения.ИдентификаторСообщения;
			ИдентификаторЧата = ИнформацияСообщения.ИдентификаторЧата;
		КонецЕсли;
	КонецПопытки;
	
	CallbackData = ДанныеCallback.data;
	
	ДанныеБезПрефикса = СтрЗаменить(CallbackData, "film_action_", "");
	ПозицияПодчёркивания = СтрНайти(ДанныеБезПрефикса, "_");
	
	Если ПозицияПодчёркивания = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Действие = Лев(ДанныеБезПрефикса, ПозицияПодчёркивания - 1);
	FilmId = Сред(ДанныеБезПрефикса, ПозицияПодчёркивания + 1);
	
	Если Действие = "facts" Тогда
		ПоказатьФактыОФильме(Отправитель, FilmId, ИдентификаторЧата, ИдСообщения, ТекущийСтатус, 1);
	ИначеЕсли Действие =  "awards" Тогда
//			ПоказатьНаградыФильма(Отправитель, FilmId, ИдентификаторЧата, ИдСообщения);
	ИначеЕсли Действие = "similar" Тогда
//			ПоказатьПохожиеФильмы(Отправитель, FilmId, ИдентификаторЧата, ИдСообщения);
	ИначеЕсли Действие = "gallery" Тогда
//			ПоказатьГалереюФильма(Отправитель, FilmId, ИдентификаторЧата, ИдСообщения);
	ИначеЕсли Действие = "reviews" Тогда
//			ПоказатьРецензииФильма(Отправитель, FilmId, ИдентификаторЧата, ИдСообщения);
	ИначеЕсли Действие = "back" Тогда
		ВернутьсяКРодительскомуКонтекстуФильма(Отправитель, FilmId, ИдентификаторЧата, ИдСообщения, ТекущийСтатус);	
	Иначе
		ВызватьИсключение "Неизвестное действие";
	КонецЕсли;
	
КонецПроцедуры


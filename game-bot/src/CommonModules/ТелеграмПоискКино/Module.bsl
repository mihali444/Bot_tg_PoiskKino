												  ИДСообщения, 
												  "❌ Не удалось загрузить информацию об актёре. Попробуйте ещё раз.");
		РаботаСоСтатусом.УстановитьСтатус(Отправитель, Перечисления.СтатусыПоискКино.ВыборФильма);
		Возврат;
	КонецЕсли;
	
	ПоказатьДеталиАктера(Отправитель, ДеталиАктера, ИДСообщения, ИдПользователя, ТекущийСтатус);
КонецПроцедуры

Процедура ПоказатьДеталиАктера(Отправитель, ДеталиАктера, ИДСообщения, ИдПользователя, ТекущийСтатус)
	
	Если ТекущийСтатус = Неопределено Тогда
		ТекущийСтатус = РаботаСоСтатусом.СтатусОтправителя(Отправитель);
	КонецЕсли;
	
	Актер = ОбработатьJSON(Отправитель, ДеталиАктера);
	
	Обложка = ПолучитьДвоичныеДанныеОбложки(?(Актер.Свойство("posterUrl"), 
									   Актер["posterUrl"], 
									   Неопределено));
	
	Имя = ?(Актер.Свойство("nameRu"), Актер["nameRu"], Актер["nameEn"]);
	ДеньРождения = СтрЗаменить(?(Актер.Свойство("birthday"), Актер["birthday"], "-"), Символы.НПП, "");
	Возраст = ?(Актер.Свойство("age"), Актер["age"], "-");
	Рост = ?(Актер.Свойство("growth"), Актер["growth"], "-");
	ДатаСмерти = ?(Актер["death"] <> Неопределено, Актер["death"], "-");
	МестоРождения = ?(Актер.Свойство("birthplace"), Актер["birthplace"], "-");
	Профессии = ?(Актер.Свойство("profession"), Актер["profession"], "-");
	
	Если ДатаСмерти = "-" Тогда
		ТекстОбАктёре = СтрШаблон("
			|🎭 <b>%1</b>
			|
			|🎬 <b>Профессия:</b> %2
			|🎂 <b>Дата рождения:</b> %3 (%4 лет)
			|📍 <b>Место рождения:</b> %5
			|📏 <b>Рост:</b> %6 см",
			Имя,
			Профессии,
			ДеньРождения,
			Возраст,
			МестоРождения,
			Рост);
	Иначе
		ТекстОбАктёре = СтрШаблон("
			|🎭 <b>%1</b> 🕯️
			|
			|🎬 <b>Профессия:</b> %2
			|🎂 <b>Дата рождения:</b> %3
			|✝️ <b>Дата смерти:</b> %4
			|📍 <b>Место рождения:</b> %5
			|📏 <b>Рост:</b> %6 см",
			Имя,
			Профессии,
			ДеньРождения,
			ДатаСмерти,
			МестоРождения,
			Рост);
	КонецЕсли;
	
	ИДАктера = РаботаСТекстом.ОчиститьИдентификатор(Актер["personId"], " ");
	
	Клавиатура = Клавиатуры.КлавиатураСтраницыАктера(ИДАктера);

	ДополнительныеСвойства = ИнтеграцияТелеграм.ДополнительныеСвойстваИсходящегоСообщения();
	ДополнительныеСвойства.Клавиатура = Клавиатура;
	
	МаксДлинаСообщения = 1024;
	
	Если Обложка = Неопределено Тогда
		ИнтеграцияТелеграм.РедактироватьСообщение(ИдПользователя, ИДСообщения, ТекстОбАктёре, ДополнительныеСвойства);
	Иначе
		Если СтрДлина(ТекстОбАктёре) > МаксДлинаСообщения Тогда
			ТекстОбАктёре = РаботаСТекстом.ОбрезатьТекстДляПодписи(ТекстОбАктёре, МаксДлинаСообщения);
		КонецЕсли;
		ИнтеграцияТелеграм.УдалитьСообщение(ИдПользователя, ИДСообщения);
		ИнтеграцияТелеграм.ОтправитьКартинку(Отправитель, Обложка, ТекстОбАктёре, ДополнительныеСвойства);
	КонецЕсли;
	
	РодительскийКонтекст = Неопределено;
	
	Если ТекущийСтатус <> Неопределено И ТекущийСтатус.ДополнительныеДанные <> Неопределено Тогда
		Если ТекущийСтатус.Статус = Перечисления.СтатусыПоискКино.ВыборАктёра Тогда
			РодительскийКонтекст = Новый Структура;
			РодительскийКонтекст.Вставить("Статус", Перечисления.СтатусыПоискКино.ВыборАктёра);
			РодительскийКонтекст.Вставить("Данные", ТекущийСтатус.ДополнительныеДанные.Получить());
		КонецЕсли;
	КонецЕсли;
	
	КэшАктера = Новый Структура;
	КэшАктера.Вставить("ИДАктера", ИДАктера);
	КэшАктера.Вставить("ТекстОбАктёре", ТекстОбАктёре);
	КэшАктера.Вставить("Обложка", Обложка);
	КэшАктера.Вставить("ИдЧата", ИдПользователя);
	КэшАктера.Вставить("ДатаКеширования", ТекущаяДатаСеанса());
	
	Если РодительскийКонтекст <> Неопределено Тогда
		КэшАктера.Вставить("РодительскийКонтекст", РодительскийКонтекст);
	КонецЕсли;
	
	РаботаСоСтатусом.УстановитьСтатус(Отправитель, Перечисления.СтатусыПоискКино.СтраницаАктера, КэшАктера);
	
КонецПроцедуры

Функция ПолучитьДвоичныеДанныеОбложки(URLартинки)
	
	АдресБезПротокола = СтрЗаменить(URLартинки, "https://", "");
	АдресСервера = Лев(АдресБезПротокола, СтрНайти(АдресБезПротокола, "/") - 1);
	СсылкаБезАдреса = Сред(АдресБезПротокола, СтрНайти(АдресБезПротокола, "/"));

	
	HTTPСоединение = Новый HTTPСоединение(АдресСервера, , , , , Истина);
		
	HTTPЗапрос = Новый HTTPЗапрос(СсылкаБезАдреса);
	
	HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json");
	HTTPЗапрос.Заголовки.Вставить("X-API-KEY", Константы.КлючAPIКиноПоиск.Получить());
	
	//@skip-check bsl-legacy-check-dynamic-feature-access - Асинх только на клиенте
	Ответ = HTTPСоединение.Получить(HTTPЗапрос);
	
	Если Ответ.КодСостояния = 200 Тогда
		Возврат Ответ.ПолучитьТелоКакДвоичныеДанные();
	ИначеЕсли Ответ.КодСостояния = 301 ИЛИ Ответ.КодСостояния = 302 Тогда
		Возврат ПолучитьДвоичныеДанныеОбложки(Ответ.Заголовки["Location"]);
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

Функция ОбработатьJSON(Отправитель, Результат)
	
	СтрокаJSON = Результат.ПолучитьТелоКакСтроку();
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
	
	Попытка
		Результат = ПрочитатьJSON(ЧтениеJSON);
	Исключение
		Возврат "Не удалось прочитать JSON";
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция ЗапросКСерверуПоискФильма(Отправитель, Текст)
	
	АдресСервера = Константы.АдресСервера.Получить();
	КлючеваяФраза = КодироватьСтроку(Текст, СпособКодированияСтроки.URLВКодировкеURL);
	
	Метод = "/api/v2.1/films/search-by-keyword";
	
	МетодСФразой = Метод + "?keyword=" + КлючеваяФраза;
	
	HTTPСоединение = Новый HTTPСоединение(АдресСервера, , , , , Истина);
	
	HTTPЗапрос = Новый HTTPЗапрос(МетодСФразой);
	
	HTTPЗапрос.Заголовки.Вставить("Content-Type", "application/json");
	HTTPЗапрос.Заголовки.Вставить("X-API-KEY", Константы.КлючAPIКиноПоиск.Получить());
	
	//@skip-check bsl-legacy-check-dynamic-feature-access - Асинх только на клиенте
	Ответ = HTTPСоединение.Получить(HTTPЗапрос);
	
	Если Ответ.КодСостояния = 200 Тогда
		Возврат Ответ;
	ИначеЕсли Ответ.КодСостояния = 404 Тогда
		Возврат 1;
	Иначе
		Возврат 2;
	КонецЕсли;
	

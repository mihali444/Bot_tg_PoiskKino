#Область ПрограммныйИнтерфейс

// Удаляет указанный префикс и все пробельные символы из исходной строки.
//
// Параметры:
//   Строка - Строка - Исходная строка для обработки
//   Префикс - Строка - Удаляемый префикс
//
// Возвращаемое значение:
//   Строка - Очищенная строка без префикса и пробельных символов
Функция ОчиститьИдентификатор(Строка, Префикс) Экспорт
    
    Если Строка = Неопределено Тогда
        Возврат "";
    КонецЕсли;
    
    Результат = СтрЗаменить(Строка, Префикс, "");
    
    Буфер = Новый Массив;
    Для Н = 1 По СтрДлина(Результат) Цикл
        Символ = Сред(Результат, Н, 1);
        Если Символ <> " " И Символ <> Символы.ТАБ И Символ <> Символы.ПС 
           И Символ <> Символы.ВК И Символ <> Символы.НПП Тогда
            Буфер.Добавить(Символ);
        КонецЕсли;
    КонецЦикла;
    
    Возврат СтрСоединить(Буфер, "");
    
КонецФункции

// Заменяет специальные символы в тексте на их HTML-эквиваленты для корректного отображения в браузере.
//
// Параметры:
//   Текст - Строка, Неопределено - Исходный текст, который необходимо экранировать.
//
// Возвращаемое значение:
//   Строка - Экранированный текст с замененными символами &, <, >.
Функция ЭкранироватьHTML(Текст) Экспорт
    
    Если Текст = Неопределено Или Текст = "" Тогда
        Возврат "";
    КонецЕсли;
    
    Если СтрНайти(Текст, "&") = 0 И СтрНайти(Текст, "<") = 0 И СтрНайти(Текст, ">") = 0 Тогда
        Возврат Текст;
    КонецЕсли;
    
    Результат = СтрЗаменить(Текст, "&", "&amp;");
    Результат = СтрЗаменить(Результат, "<", "&lt;");
    Результат = СтрЗаменить(Результат, ">", "&gt;");
    
    Возврат Результат;
    
КонецФункции

// Очищает текст от HTML-тегов, декодирует HTML-сущности и экранирует специальные символы.
//
// Параметры:
//   Текст - Строка - Исходный текст, содержащий HTML-разметку
//
// Возвращаемое значение:
//   Строка - Очищенный текст без HTML-тегов с экранированными символами
Функция ОчиститьТекстОтHTML(Текст) Экспорт
    
    Если Текст = Неопределено Или Текст = "" Тогда
        Возврат "";
    КонецЕсли;
    
    Буфер = Новый Массив;
    ВнутриТега = Ложь;
    
    Для Н = 1 По СтрДлина(Текст) Цикл
        Символ = Сред(Текст, Н, 1);
        
        Если Символ = "<" Тогда
            ВнутриТега = Истина;
        ИначеЕсли Символ = ">" Тогда
            ВнутриТега = Ложь;
        ИначеЕсли Не ВнутриТега Тогда
            Буфер.Добавить(Символ);
        КонецЕсли;
    КонецЦикла;
    
    Результат = СтрСоединить(Буфер, "");
    
    Результат = ДекодироватьHTMLСущности(Результат);
    
    Если СтрНайти(Результат, "&") > 0 ИЛИ СтрНайти(Результат, "<") > 0 ИЛИ СтрНайти(Результат, ">") > 0 Тогда
        Результат = СтрЗаменить(Результат, "&", "&amp;");
        Результат = СтрЗаменить(Результат, "<", "&lt;");
        Результат = СтрЗаменить(Результат, ">", "&gt;");
    КонецЕсли;
    
    Возврат Результат;
    
КонецФункции

// Обрезает текст до указанной длины, корректно закрывая HTML-теги жирного и курсивного начертания.
//
// Параметры:
//   Текст - Строка - исходный текст для обработки
//   МаксДлина - Число - максимальная длина возвращаемой строки (по умолчанию 1024)
//
// Возвращаемое значение:
//   Строка - обрезанный текст с закрывающими тегами и многоточием в конце
Функция ОбрезатьТекстДляПодписи(Текст, МаксДлина = 1024) Экспорт
    
    Если Текст = Неопределено Или СтрДлина(Текст) <= МаксДлина Тогда
        Возврат Текст;
    КонецЕсли;
    
    ОбрезанныйТекст = Лев(Текст, МаксДлина - 3);
    
    СчётчикB = 0; // +1 для <b>, -1 для </b>
    СчётчикI = 0; // +1 для <i>, -1 для </i>
    
    Позиция = 1;
    Пока Позиция <= СтрДлина(ОбрезанныйТекст) Цикл

        НачалоТега = СтрНайти(ОбрезанныйТекст, "<", , Позиция);
        Если НачалоТега = 0 Тогда Прервать; КонецЕсли;
        
        КонецТега = СтрНайти(ОбрезанныйТекст, ">", , НачалоТега);
        Если КонецТега = 0 Тогда Прервать; КонецЕсли;
        
        Тег = Сред(ОбрезанныйТекст, НачалоТега, КонецТега - НачалоТега + 1);
        
        Если Тег = "<b>" Тогда
            СчётчикB = СчётчикB + 1;
        ИначеЕсли Тег = "</b>" Тогда
            СчётчикB = СчётчикB - 1;
        ИначеЕсли Тег = "<i>" Тогда
            СчётчикI = СчётчикI + 1;
        ИначеЕсли Тег = "</i>" Тогда
            СчётчикI = СчётчикI - 1;
        КонецЕсли;
        
        Позиция = КонецТега + 1;
    КонецЦикла;
    
    Если СчётчикI > 0 Тогда
        Для Счётчик = 1 По СчётчикI Цикл
            ОбрезанныйТекст = ОбрезанныйТекст + "</i>";
        КонецЦикла;
    КонецЕсли;
    
    Если СчётчикB > 0 Тогда
        Для Счётчик = 1 По СчётчикB Цикл
            ОбрезанныйТекст = ОбрезанныйТекст + "</b>";
        КонецЦикла;
    КонецЕсли;
    
    Возврат ОбрезанныйТекст + "...";
    
КонецФункции
#КонецОбласти

#Область СлужебныеПроцедурыИФункции
Функция ДекодироватьHTMLСущности(Текст)
    
    Если Текст = Неопределено Или Текст = "" Тогда
        Возврат "";
    КонецЕсли;
    
    Если СтрНайти(Текст, "&") = 0 Тогда
        Возврат Текст;
    КонецЕсли;
    
    Результат = Текст;
    
    Результат = СтрЗаменить(Результат, "&laquo;", "«");
    Результат = СтрЗаменить(Результат, "&raquo;", "»");
    Результат = СтрЗаменить(Результат, "&quot;", """");
    Результат = СтрЗаменить(Результат, "&nbsp;", " ");
    Результат = СтрЗаменить(Результат, "&ndash;", "–");
    Результат = СтрЗаменить(Результат, "&mdash;", "—");
    
    Если СтрНайти(Результат, "&#") > 0 Тогда
        Результат = ДекодироватьЧисловыеСущности(Результат);
    КонецЕсли;
    
    Результат = СтрЗаменить(Результат, "&amp;", "&");
    
    Возврат Результат;
    
КонецФункции

Функция ДекодироватьЧисловыеСущности(Текст)
    
    Результат = Текст;
    Позиция = 1;
    
    Пока Истина Цикл

        Начало = СтрНайти(Результат, "&#", , Позиция);
        Если Начало = 0 Тогда Прервать; КонецЕсли;
        
        Конец = СтрНайти(Результат, ";", , Начало);
        Если Конец = 0 Тогда Прервать; КонецЕсли;
        
        Сущность = Сред(Результат, Начало, Конец - Начало + 1);
        КодСимвола = СтрЗаменить(СтрЗаменить(Сущность, "&#", ""), ";", "");
        
        Попытка
            Код = Число(КодСимвола);

            Если Код > 0 И Код < 65535 Тогда
                Символ = Символ(Код);
                Результат = СтрЗаменить(Результат, Сущность, Символ);

                Позиция = Начало + СтрДлина(Символ);
            Иначе
                Позиция = Конец + 1;
            КонецЕсли;
        Исключение
            Позиция = Конец + 1;
        КонецПопытки;
    КонецЦикла;
    
    Возврат Результат;
    
КонецФункции

#КонецОбласти
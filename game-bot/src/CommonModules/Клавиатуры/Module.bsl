#Область ПрограммныйИнтерфейс
// Формирует встроенную клавиатуру для навигации по страницам с фактами о фильме.
//
// Параметры:
//   FilmId - Строка - идентификатор фильма
//   ТекущаяСтраница - Число - номер текущей страницы
//   ВсегоСтраниц - Число - общее количество страниц
//   Префикс - Строка - префикс для формирования данных кнопок (по умолчанию "film_facts_")
//
// Возвращаемое значение:
//   Структура - структура в формате inline_keyboard для API бота
Функция КлавиатураФактов(FilmId, ТекущаяСтраница, ВсегоСтраниц, Префикс = "film_facts_") Экспорт
	
	СтрокиКлавиатуры = Новый Массив;
	
	Строка1 = Новый Массив;
	
	Если ТекущаяСтраница > 1 Тогда
		КнопкаНазадФакты = Новый Структура;
		КнопкаНазадФакты.Вставить("text", "⬅️ Назад");
		КнопкаНазадФакты.Вставить("callback_data", 
								  Префикс + "prev_" + Строка(FilmId) + "_" + Строка(ТекущаяСтраница - 1));
		Строка1.Добавить(КнопкаНазадФакты);
	КонецЕсли;
	
	КнопкаСтраница = Новый Структура;
	КнопкаСтраница.Вставить("text", СтрШаблон("%1/%2", ТекущаяСтраница, ВсегоСтраниц));
	КнопкаСтраница.Вставить("callback_data", Префикс + "page_" + Строка(FilmId));
	Строка1.Добавить(КнопкаСтраница);
	
	Если ТекущаяСтраница < ВсегоСтраниц Тогда
		КнопкаВперёдФакты = Новый Структура;
		КнопкаВперёдФакты.Вставить("text", "Вперёд ➡️");
		КнопкаВперёдФакты.Вставить("callback_data", Префикс + "next_" + Строка(FilmId) + "_" + Строка(ТекущаяСтраница + 1));
		Строка1.Добавить(КнопкаВперёдФакты);
	КонецЕсли;
	
	СтрокиКлавиатуры.Добавить(Строка1);
	
	Строка2 = Новый Массив;
	
	КнопкаКФильму = Новый Структура;
	КнопкаКФильму.Вставить("text", "🔙 К фильму");
	КнопкаКФильму.Вставить("callback_data", Префикс + "back_" + Строка(FilmId));
	Строка2.Добавить(КнопкаКФильму);
	
	СтрокиКлавиатуры.Добавить(Строка2);
	
	Клавиатура = Новый Структура;
	Клавиатура.Вставить("inline_keyboard", СтрокиКлавиатуры);
	
	Возврат Клавиатура;
	
КонецФункции

// Формирует структуру инлайн-клавиатуры для страницы с информацией о фильме.
//
// Параметры:
//   FilmId - Строка - Идентификатор фильма
//   Префикс - Строка - Префикс для формирования callback_data кнопок (по умолчанию "film_action_")
//
// Возвращаемое значение:
//   Структура - Структура клавиатуры в формате API (inline_keyboard)
Функция КлавиатураСтраницыФильма(FilmId, Префикс = "film_action_") Экспорт
	
	СтрокиКлавиатуры = Новый Массив;
	
	Строка1 = Новый Массив;
	
	КнопкаФакты = Новый Структура;
	КнопкаФакты.Вставить("text", "📚 Факты");
	КнопкаФакты.Вставить("callback_data", Префикс + "facts_" + FilmId);
	Строка1.Добавить(КнопкаФакты);
	
	КнопкаНаграды = Новый Структура;
	КнопкаНаграды.Вставить("text", "🏆 Награды");
	КнопкаНаграды.Вставить("callback_data", Префикс + "awards_" + FilmId);
	Строка1.Добавить(КнопкаНаграды);
	
	СтрокиКлавиатуры.Добавить(Строка1);
	
	Строка2 = Новый Массив;
	
	КнопкаПохожие = Новый Структура;
	КнопкаПохожие.Вставить("text", "🎬 Похожие");
	КнопкаПохожие.Вставить("callback_data", Префикс + "similar_" + FilmId);
	Строка2.Добавить(КнопкаПохожие);
	
	КнопкаГалерея = Новый Структура;
	КнопкаГалерея.Вставить("text", "🖼️ Снимки, арты и т.д.");
	КнопкаГалерея.Вставить("callback_data", Префикс + "gallery_" + FilmId);
	Строка2.Добавить(КнопкаГалерея);
	
	СтрокиКлавиатуры.Добавить(Строка2);
	
	Строка3 = Новый Массив;
	
	КнопкаРецензии = Новый Структура;
	КнопкаРецензии.Вставить("text", "✍️ Рецензии");
	КнопкаРецензии.Вставить("callback_data", Префикс + "reviews_" + FilmId);
	Строка3.Добавить(КнопкаРецензии);
	
	СтрокиКлавиатуры.Добавить(Строка3);
	
	Строка4 = Новый Массив;
	
	КнопкаНазад = Новый Структура;
	КнопкаНазад.Вставить("text", "🔙 Назад");
	КнопкаНазад.Вставить("callback_data", Префикс + "back_" + FilmId);
	Строка4.Добавить(КнопкаНазад);
	
	СтрокиКлавиатуры.Добавить(Строка4);
	
	Клавиатура = Новый Структура;
	Клавиатура.Вставить("inline_keyboard", СтрокиКлавиатуры);
	
	Возврат Клавиатура;
	
КонецФункции

// Формирует структуру для удаления клавиатуры в чат-боте.
//
// Возвращаемое значение:
//   Структура - структура с полем remove_keyboard, равным Истина, для удаления клавиатуры
Функция УдалитьКлавиатуру() Экспорт
	
	Клавиатура = Новый Структура;
	Клавиатура.Вставить("remove_keyboard", Истина);
	
	Возврат Клавиатура;
	
КонецФункции

// Формирует клавиатуру с кнопками для каждого фильма из массива.
//
// Параметры:
//   МассивФильмов - Произвольный - массив структур с информацией о фильмах
//
// Возвращаемое значение:
//   Структура - структура, описывающая клавиатуру для отправки в API
Функция КлавиатураНесколькоКнопок(МассивФильмов) Экспорт
	
	СтрокиКлавиатуры = Новый Массив;
	
	Для каждого Фильм Из МассивФильмов Цикл
		
		ТекстКнопки = Фильм.Название;
		Если Фильм.ГодВыпуска <> Неопределено И Фильм.ГодВыпуска <> "null" И Фильм.ГодВыпуска <> "" Тогда
			ТекстКнопки = ТекстКнопки + " (" + Фильм.ГодВыпуска + ")";
		КонецЕсли;
		
		Кнопка = Новый Структура;
		Кнопка.Вставить("text", ТекстКнопки);
		
		СтрокаКлавиатуры = Новый Массив;
		СтрокаКлавиатуры.Добавить(Кнопка);
		СтрокиКлавиатуры.Добавить(СтрокаКлавиатуры);
		
	КонецЦикла;
	
	Клавиатура = Новый Структура;
	Клавиатура.Вставить("keyboard", СтрокиКлавиатуры);
	Клавиатура.Вставить("resize_keyboard", Истина);
	Клавиатура.Вставить("one_time_keyboard", Истина);
	
	Возврат Клавиатура;
	
КонецФункции

// Формирует структуру клавиатуры с одной кнопкой для использования в боте.
//
// Параметры:
//   Заголовок - Строка - Текст, отображаемый на кнопке
//
// Возвращаемое значение:
//   Структура - Структура, описывающая клавиатуру с одной кнопкой и настройкой автоматического изменения размера
Функция КлавиатураОднаКнопка(Заголовок) Экспорт
	
	СтрокиКлавиатуры = Новый Массив;
	СтрокаКлавиатуры = Новый Массив;
	
	Кнопка = Новый Структура;
	Кнопка.Вставить("text", Заголовок);
	
	СтрокаКлавиатуры.Добавить(Кнопка);	
	СтрокиКлавиатуры.Добавить(СтрокаКлавиатуры);

	Клавиатура = Новый Структура;
	Клавиатура.Вставить("keyboard", СтрокиКлавиатуры);
	Клавиатура.Вставить("resize_keyboard", Истина);	
	
	Возврат Клавиатура;
	
КонецФункции

// Формирует структуру встроенной клавиатуры для выбора фильма.
//
// Параметры:
//   МассивФильмов - Произвольный - Список фильмов с полями Название, ГодВыпуска и id
//   Префикс - Строка - Префикс для формирования идентификатора нажатия кнопки
//
// Возвращаемое значение:
//   Структура - Структура клавиатуры в формате API бота
Функция КлавиатураФильмовInline(МассивФильмов, Префикс = "film_") Экспорт
	
	СтрокиКлавиатуры = Новый Массив;
	
	Для каждого Фильм Из МассивФильмов Цикл
		
		ТекстКнопки = Фильм.Название;
		Если Фильм.ГодВыпуска <> Неопределено И Фильм.ГодВыпуска <> "null" И Фильм.ГодВыпуска <> "" Тогда
			ТекстКнопки = ТекстКнопки + " (" + Фильм.ГодВыпуска + ")";
		КонецЕсли;
		
		CallbackData = Префикс + Фильм.id;
		
		Кнопка = Новый Структура;
		Кнопка.Вставить("text", ТекстКнопки);
		Кнопка.Вставить("callback_data", CallbackData);
		
		СтрокаКлавиатуры = Новый Массив;
		СтрокаКлавиатуры.Добавить(Кнопка);
		СтрокиКлавиатуры.Добавить(СтрокаКлавиатуры);
		
	КонецЦикла;
	
	Клавиатура = Новый Структура;
	Клавиатура.Вставить("inline_keyboard", СтрокиКлавиатуры);
	Клавиатура.Вставить("one_time_keyboard", Истина);
	
	Возврат Клавиатура;
	
КонецФункции

#КонецОбласти